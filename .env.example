# --- Database ---------------------------------------------------------------
# Local Postgres example. If you don't have Postgres installed, the fastest
# path is `docker run --name vault-db -e POSTGRES_PASSWORD=postgres -p 5432:5432 -d postgres:16`
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/vault?schema=public"

# --- Auth (Better Auth) ------------------------------------------------------
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=""
BETTER_AUTH_URL="http://localhost:3000"
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# --- Field-level encryption ---------------------------------------------------
# Used to encrypt API keys, license keys, and notes at rest (AES-256-GCM).
# Must decode to exactly 32 bytes. Generate with: openssl rand -base64 32
ENCRYPTION_KEY=""
