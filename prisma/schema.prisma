// ==========================================================================
// Personal AI Asset Manager — Database Schema
// PostgreSQL + Prisma
//
// Design notes:
// - Single-tenant-per-user model: every domain row is scoped by userId so the
//   schema is ready for multi-user (family/team) use later without a rewrite.
// - Secrets (API keys, license keys, sensitive notes) are stored as
//   ciphertext strings (AES-256-GCM, see src/lib/encryption.ts). The DB never
//   sees plaintext.
// - Money is stored as Int cents (never Float) to avoid rounding drift.
// - CustomField/AttachmentValue pattern keeps the schema open-ended without
//   needing a migration every time a user wants a new field.
// ==========================================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --------------------------------------------------------------------------
// Auth (Better Auth compatible shape)
// --------------------------------------------------------------------------

model User {
  id            String    @id @default(cuid())
  name          String
  email         String    @unique
  emailVerified Boolean   @default(false)
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  sessions      Session[]
  accounts      Account[]

  categories       Category[]
  assets           Asset[]
  calendarEvents   CalendarEvent[]
  activityLogs     ActivityLog[]
  notificationPrefs NotificationPreference?

  @@map("users")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  @@index([identifier])
  @@map("verifications")
}

// --------------------------------------------------------------------------
// Core domain
// --------------------------------------------------------------------------

enum AssetStatus {
  ACTIVE
  TRIAL
  EXPIRED
  CANCELLED
  ARCHIVED
}

enum BillingCycle {
  MONTHLY
  YEARLY
  LIFETIME
  TRIAL
  FREE
  ONE_TIME
  CUSTOM
}

enum CreditPeriod {
  DAILY
  MONTHLY
  LIFETIME
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

model Category {
  id        String   @id @default(cuid())
  userId    String
  name      String
  slug      String
  icon      String?
  color     String?
  isSystem  Boolean  @default(false)
  createdAt DateTime @default(now())

  user   User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  assets Asset[]

  @@unique([userId, slug])
  @@index([userId])
  @@map("categories")
}

model Asset {
  id         String   @id @default(cuid())
  userId     String
  categoryId String?

  // Identity
  name        String
  logoUrl     String?
  description String?
  vendor      String?
  websiteUrl  String?
  billingUrl  String?
  dashboardUrl String?
  planName    String?

  // Status & lifecycle
  status     AssetStatus  @default(ACTIVE)
  billingCycle BillingCycle @default(MONTHLY)
  purchaseDate  DateTime?
  startDate     DateTime?
  renewalDate   DateTime?
  expirationDate DateTime?
  autoRenew     Boolean      @default(true)

  // Money — stored as integer minor units (cents) to avoid float drift
  priceCents   Int?     @default(0)
  currency     String   @default("USD")

  // Purchase / accounting metadata
  paymentMethod  String?
  invoiceNumber  String?
  purchasedFrom  String?
  orderId        String?

  // Secrets — always ciphertext (AES-256-GCM), never plaintext
  licenseKeyEncrypted String?
  apiKeyEncrypted     String?
  notesEncrypted      String?

  // Account metadata
  emailUsed      String?
  username       String?
  twoFactorEnabled Boolean @default(false)
  recoveryEmail  String?

  // Organization
  tags       String[] @default([])
  priority   Priority @default(MEDIUM)
  isFavorite Boolean  @default(false)
  isHidden   Boolean  @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user        User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category?         @relation(fields: [categoryId], references: [id])
  credits     CreditBalance[]
  attachments Attachment[]
  customFields CustomFieldValue[]
  reminders   Reminder[]
  calendarEvents CalendarEvent[]
  activityLogs ActivityLog[]

  @@index([userId])
  @@index([userId, status])
  @@index([userId, renewalDate])
  @@index([categoryId])
  @@map("assets")
}

model CreditBalance {
  id         String       @id @default(cuid())
  assetId    String
  period     CreditPeriod @default(MONTHLY)
  totalCredits    Float
  usedCredits     Float   @default(0)
  resetsAt        DateTime?
  lastResetAt     DateTime?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@map("credit_balances")
}

model Attachment {
  id        String   @id @default(cuid())
  assetId   String
  fileName  String
  fileType  String
  fileSizeBytes Int
  category  String   // invoice | receipt | license | contract | screenshot | other
  storageKey String  // key/path in the storage adapter (see lib/storage)
  createdAt DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@map("attachments")
}

model CustomFieldValue {
  id        String   @id @default(cuid())
  assetId   String
  label     String
  value     String
  createdAt DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@map("custom_field_values")
}

model Reminder {
  id           String   @id @default(cuid())
  assetId      String
  daysBefore   Int      // 30, 14, 7, 3, 1, 0 = expiry day, negative not allowed
  isCustom     Boolean  @default(false)
  channel      String   @default("IN_APP") // IN_APP | EMAIL | BROWSER
  triggeredAt  DateTime?
  createdAt    DateTime @default(now())

  asset Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)

  @@index([assetId])
  @@map("reminders")
}

model CalendarEvent {
  id        String   @id @default(cuid())
  userId    String
  assetId   String?
  title     String
  type      String   // RENEWAL | CREDIT_RESET | INVOICE | PAYMENT | EXPIRY | CUSTOM
  date      DateTime
  notes     String?
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset Asset? @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@index([userId, date])
  @@map("calendar_events")
}

model NotificationPreference {
  id            String  @id @default(cuid())
  userId        String  @unique
  inAppEnabled  Boolean @default(true)
  emailEnabled  Boolean @default(false)
  browserEnabled Boolean @default(false)
  defaultReminderDays Int[] @default([30, 7, 1])

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model ActivityLog {
  id        String   @id @default(cuid())
  userId    String
  assetId   String?
  action    String   // CREATED | UPDATED | ARCHIVED | DELETED | RENEWED | FAVORITED ...
  metadata  Json?
  createdAt DateTime @default(now())

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  asset Asset? @relation(fields: [assetId], references: [id], onDelete: SetNull)

  @@index([userId, createdAt])
  @@map("activity_logs")
}
